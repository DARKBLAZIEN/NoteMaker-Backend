<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Backend Project</title>
</head>
<body>
    <div class="bg-zinc-900 w-full min-h-screen main">
        <h1 class=" heading pl-6 pt-5">Note Maker</h1>
        <div class="form-surround">
            <form action="/create" method="post">
                <input name="title" type="text" class=" block rounded-md title w-full bg-zinc-800 font-montserrat p-3" placeholder="title of your">
                <textarea name="details" type="text" class="block resize-none mt-2 rounded-md w-full bg-zinc-800 p-3" placeholder="Type your notes..."></textarea>
                <input  type="submit" class="submit-button rounded-md p-3 mt-5" value="Create task">
            </form>
        </div>
        <div class="tasks p-5 flex gap-5">
            <% if(files.length>0){ %>
                <% files.forEach(function(val) { %>
                    <div class=" display-tasks p-4 w-72 bg-zinc-800  rounded">
                        <h1 class="font-montserrat tracking-tighter w-72 pl-2 text-2xl text-white"><%= val %></h1>
                        <a href="#" class="text-blue-600 pl-2 pt-2 ">Read more</a>
                    </div>
                <% }) %>
            <% } else { %>
                <h1 class="text-white font-serif opacity-40">No tasks yet</h1>
            <% } %>
            
        </div>
    </div>
    <script src="/javascripts/script.js" ></script>
</body>
</html>